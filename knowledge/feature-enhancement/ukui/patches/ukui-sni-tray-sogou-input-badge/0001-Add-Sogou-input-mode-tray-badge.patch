+void TrayItemsModel::setSogouInputBadge(const QString &badge)
+{
+    if (m_sogouInputBadge == badge) {
+        return;
+    }
+
+    m_sogouInputBadge = badge;
+    for (int i = 0; i < m_item.size(); ++i) {
+        if (m_item.at(i)->id() == QStringLiteral("Fcitx")) {
+            Q_EMIT dataChanged(index(i, 0, {}), index(i, 0, {}), {Role::SogouInputBadge});
+        }
+    }
+}
+
+void TrayItemsModel::refreshSogouInputBadge()
+{
+    if (m_sogouInputBadgeRefreshing) {
+        m_sogouInputBadgeRefreshQueued = true;
+        return;
+    }
+    m_sogouInputBadgeRefreshQueued = false;
+
+    bool hasSogouFcitxItem = false;
+    for (const TrayItem *item : m_item) {
+        if (item->id() == QStringLiteral("Fcitx")
+                && item->iconName().contains(QStringLiteral("sogou"), Qt::CaseInsensitive)) {
+            hasSogouFcitxItem = true;
+            break;
+        }
+    }
+    if (!hasSogouFcitxItem) {
+        setSogouInputBadge(QString());
+        return;
+    }
+
+    const QString user = currentUserName();
+    if (user.isEmpty()) {
+        setSogouInputBadge(QString());
+        return;
+    }
+
+    QDBusInterface panel(QStringLiteral("com.cpis.panel"),
+                         QStringLiteral("/com/cpis/panel"),
+                         QStringLiteral("com.cpis.panel"),
+                         QDBusConnection::sessionBus());
+    if (!panel.isValid()) {
+        setSogouInputBadge(QString());
+        return;
+    }
+
+    m_sogouInputBadgeRefreshing = true;
+    const QString uid = user + QStringLiteral("#im.module=fcitx5|im.name=com.sogou.ime.ng.fcitx5.kylin");
+    QDBusPendingCall call = panel.asyncCall(QStringLiteral("AcquireEngineStat"),
+                                            uid,
+                                            QStringLiteral("current_mode"));
+    auto *watcher = new QDBusPendingCallWatcher(call, this);
+    connect(watcher, &QDBusPendingCallWatcher::finished, this, [this](QDBusPendingCallWatcher *watcher) {
+        m_sogouInputBadgeRefreshing = false;
+        QDBusPendingReply<QString, int> reply = *watcher;
+        if (reply.isError()) {
+            setSogouInputBadge(QString());
+        } else {
+            setSogouInputBadge(sogouBadgeFromMode(reply.argumentAt<0>()));
+        }
+        watcher->deleteLater();
+        if (m_sogouInputBadgeRefreshQueued) {
+            QTimer::singleShot(0, this, &TrayItemsModel::refreshSogouInputBadge);
+        }
+    });
+}
+
+void TrayItemsModel::scheduleSogouInputBadgeRefresh()
+{
+    QTimer::singleShot(0, this, &TrayItemsModel::refreshSogouInputBadge);
+}
+
+void TrayItemsModel::onSogouEngineEvent(const QString &uid, int type, const QByteArray &payload, uint serial)
+{
+    Q_UNUSED(type)
+    Q_UNUSED(payload)
+    Q_UNUSED(serial)
+    if (uid.contains(QStringLiteral("com.sogou.ime.ng.fcitx5.kylin"))) {
+        scheduleSogouInputBadgeRefresh();
+    }
+}
+
+void TrayItemsModel::onSogouPanelEvent(const QString &uid, const QByteArray &payload, uint serial)
+{
+    Q_UNUSED(payload)
+    Q_UNUSED(serial)
+    if (uid.contains(QStringLiteral("com.sogou.ime.ng.fcitx5.kylin"))) {
+        scheduleSogouInputBadgeRefresh();
+    }
+}
