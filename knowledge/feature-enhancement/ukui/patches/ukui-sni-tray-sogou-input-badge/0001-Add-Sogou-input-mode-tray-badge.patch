+static QString currentUserName()
+{
+    QString user = qEnvironmentVariable("USER");
+    if (user.isEmpty()) {
+        user = qEnvironmentVariable("LOGNAME");
+    }
+    return user;
+}
+
+static QString sogouBadgeFromMode(const QString &mode)
+{
+    const QString text = mode.toLower();
+    if (text.contains(QStringLiteral("kb_en"))
+            || text.contains(QStringLiteral("@en_us"))
+            || text.contains(QStringLiteral("26keyenglish"))
+            || text.contains(QStringLiteral("invalid"))) {
+        return QStringLiteral("英");
+    }
+    if (text.contains(QStringLiteral("kb_zh"))
+            || text.contains(QStringLiteral("@zh_cn"))
+            || text.contains(QStringLiteral("26keyzhong"))) {
+        return QStringLiteral("中");
+    }
+    return {};
+}
